# Evolution API
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_GLOBAL_KEY=your_global_api_key_here

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=evolution
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# OpenRouter (LLM)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
YOUR_SITE_URL=http://localhost
YOUR_SITE_NAME="Chatbot Langchain WhatsApp"

# Evolution API - Instância (Client Config)
EVOLUTION_API_KEY=your_instance_api_key_here
EVOLUTION_INSTANCE_NAME=your_instance_name_here

# Database URL (LangGraph Checkpointer)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/evolution

# App Config
ALLOWED_PHONE_NUMBER=5511999999999
PORT=3000
